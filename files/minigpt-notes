Those numbers start as random noise — they only become meaningful through training (Stage 4).

The code
pythonimport random
import math

class EmbeddingTable:
    def __init__(self, vocab_size, embed_dim):
        self.vocab_size = vocab_size
        self.embed_dim = embed_dim
        # Initialize with small random numbers
        self.weights = [
            [random.gauss(0, 0.1) for _ in range(embed_dim)]
            for _ in range(vocab_size)
        ]

    def lookup(self, token_id):
        """Return the embedding vector for a single token ID."""
        return self.weights[token_id]

    def lookup_sequence(self, token_ids):
        """Return embeddings for a whole sequence of token IDs."""
        return [self.lookup(tid) for tid in token_ids]

    @staticmethod
    def cosine_similarity(a, b):
        """Measure how similar two vectors are (1.0 = identical, 0 = unrelated)."""
        dot = sum(x * y for x, y in zip(a, b))
        mag_a = math.sqrt(sum(x ** 2 for x in a))
        mag_b = math.sqrt(sum(x ** 2 for x in b))
        return dot / (mag_a * mag_b + 1e-8)



pythonclass SimpleTokenizer:
    def __init__(self):
        self.token_to_id = {}   # "hello" → 5
        self.id_to_token = {}   # 5 → "hello"
        self.next_id = 0

    def _add_token(self, token):
        """Add a new token to the vocabulary if not already there."""
        if token not in self.token_to_id:
            self.token_to_id[token] = self.next_id
            self.id_to_token[self.next_id] = token
            self.next_id += 1

    def build_vocab(self, texts):
        """Read a list of sentences and build the vocabulary."""
        for text in texts:
            for word in text.lower().split():
                self._add_token(word)
        # Add a special unknown token for words we haven't seen
        self._add_token("<UNK>")
        print(f"Vocabulary size: {len(self.token_to_id)} tokens")

    def encode(self, text):
        """Convert text → list of integer IDs."""
        words = text.lower().split()
        return [self.token_to_id.get(word, self.token_to_id["<UNK>"]) for word in words]

    def decode(self, ids):
        """Convert list of integer IDs → text."""
        return " ".join([self.id_to_token.get(i, "<UNK>") for i in ids])



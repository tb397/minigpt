The Q, K, V mechanism
Attention uses three learned matrices to transform each embedding into three roles:

Query (Q) — "what am I looking for?"
Key (K) — "what do I advertise about myself?"
Value (V) — "what information do I actually contain?"

The attention score between two tokens is just the dot product of one token's Query with another token's Key. High dot product = high attention.
score(token_i, token_j) = Q[i] · K[j]

Then normalize all scores with softmax so they sum to 1.0 → those are your attention weights.

Output for token_i = weighted sum of all Values:
  output[i] = sum(attention_weight[i][j] * V[j]  for all j)

The code
pythonimport math
import random

def dot_product(a, b):
    return sum(x * y for x, y in zip(a, b))

def softmax(scores):
    """Turn raw scores into probabilities that sum to 1."""
    max_s = max(scores)  # subtract max for numerical stability
    exps = [math.exp(s - max_s) for s in scores]
    total = sum(exps)
    return [e / total for e in exps]

def matrix_vector_multiply(matrix, vec):
    """Multiply a matrix by a vector → new vector."""
    return [dot_product(row, vec) for row in matrix]

def random_matrix(rows, cols, scale=0.1):
    return [[random.gauss(0, scale) for _ in range(cols)] for _ in range(rows)]


class SingleHeadAttention:
    def __init__(self, embed_dim, head_dim):
        self.embed_dim = embed_dim
        self.head_dim = head_dim
        self.scale = math.sqrt(head_dim)  # prevents dot products from getting too large

        # The three learned projection matrices
        self.W_q = random_matrix(head_dim, embed_dim)
        self.W_k = random_matrix(head_dim, embed_dim)
        self.W_v = random_matrix(head_dim, embed_dim)

    def forward(self, embeddings):
        """
        embeddings: list of vectors, one per token
        Returns: list of output vectors (same shape as input)
        """
        seq_len = len(embeddings)

        # Step 1: Project each embedding into Q, K, V
        queries = [matrix_vector_multiply(self.W_q, e) for e in embeddings]
        keys    = [matrix_vector_multiply(self.W_k, e) for e in embeddings]
        values  = [matrix_vector_multiply(self.W_v, e) for e in embeddings]

        # Step 2: Compute attention weights for each token
        outputs = []
        for i in range(seq_len):
            # Score token i against every other token
            scores = [dot_product(queries[i], keys[j]) / self.scale
                      for j in range(seq_len)]

            # Softmax → weights sum to 1.0
            attn_weights = softmax(scores)

            # Step 3: Weighted sum of Values
            out = [0.0] * self.head_dim
            for j in range(seq_len):
                for d in range(self.head_dim):
                    out[d] += attn_weights[j] * values[j][d]

            outputs.append(out)

        return outputs



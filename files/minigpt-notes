<script>
  const chatWindow = document.getElementById('chat-window');
  const sendBtn    = document.getElementById('send-btn');
  const status     = document.getElementById('status');

  // Load model info
  fetch('/vocab').then(r => r.json()).then(info => {
    document.getElementById('badge-vocab').textContent  = `vocab: ${info.vocab_size} tokens`;
    document.getElementById('badge-layers').textContent = `${info.num_layers} layers`;
    document.getElementById('badge-dim').textContent    = `embed dim: ${info.embed_dim}`;
  });

  function addMessage(text, role) {
    const div = document.createElement('div');
    div.className = `message ${role}`;
    div.textContent = text;
    chatWindow.appendChild(div);
    chatWindow.scrollTop = chatWindow.scrollHeight;
    return div;
  }

  function setStatus(text) {
    status.textContent = text;
  }

  function clearChat() {
    chatWindow.innerHTML = '';
    addMessage('Chat cleared. Enter a new prompt.', 'model');
  }

  async function sendPrompt() {
    const input = document.getElementById('prompt-input');
    const prompt = input.value.trim();
    if (!prompt) return;

    const temperature = parseFloat(document.querySelector('#sliders input:nth-child(1), input[type=range]').value);
    const sliders = document.querySelectorAll('input[type=range]');
    const temp   = parseFloat(sliders[0].value);
    const top_p  = parseFloat(sliders[1].value);
    const maxTok = parseInt(sliders[2].value);

    addMessage(prompt, 'user');
    sendBtn.disabled = true;
    setStatus('Generating...');

    const modelMsg = addMessage('', 'model');
    const cursor = document.createElement('span');
    cursor.className = 'cursor';
    modelMsg.appendChild(cursor);

    const response = await fetch('/generate', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ prompt, temperature: temp, top_p, max_tokens: maxTok }),
    });

    const reader = response.body.getReader();
    const decoder = new TextDecoder();
    let buffer = '';
    let tokenCount = 0;

    while (true) {
      const { done, value } = await reader.read();
      if (done) break;

      buffer += decoder.decode(value, { stream: true });
      const lines = buffer.split('\n\n');
      buffer = lines.pop();

      for (const line of lines) {
        if (!line.startsWith('data: ')) continue;
        try {
          const event = JSON.parse(line.slice(6));

          if (event.type === 'token') {
            modelMsg.insertBefore(document.createTextNode(' ' + event.text), cursor);
            tokenCount++;
            chatWindow.scrollTop = chatWindow.scrollHeight;
          } else if (event.type === 'done') {
            cursor.remove();
            setStatus(`Done — ${tokenCount} tokens generated.`);
            sendBtn.disabled = false;
          } else if (event.type === 'error') {
            cursor.remove();
            modelMsg.textContent += ` [error: ${event.text}]`;
            sendBtn.disabled = false;
          }
        } catch (e) { /* partial line, wait for more */ }
      }
    }
    sendBtn.disabled = false;
  }

  document.getElementById('prompt-input').addEventListener('keydown', e => {
    if (e.key === 'Enter') sendPrompt();
  });
</script>

